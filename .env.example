# Copy this file to .env.local and fill in real values.

# Google Gemini — required for the AI Assistant (server-side only, never NEXT_PUBLIC)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional model override (defaults to a sensible Gemini flash model)
GEMINI_MODEL=

# Clerk — optional. Leave blank to run in guest/demo mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Payments — UI only in this prototype
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Support
NEXT_PUBLIC_SUPPORT_WHATSAPP=966573902089

# Curriculum content store — how the in-app PDF viewer gets its files. The
# browser ONLY ever calls /api/content/fetch?key=... (your own Jazira URL); no
# external source name or URL is exposed. Two stores:
#
#   CONTENT_STORE=public  (default) — files live in /public/resources/<key> on
#     this server. Leave CONTENT_BASE_URL unset. Works offline / self-contained.
#
#   CONTENT_STORE=remote  — files live in YOUR own storage (e.g. a Supabase
#     Storage public bucket). Set CONTENT_BASE_URL to its base; the API streams
#     from it server-side. Only keys in your catalog, host-pinned (SSRF-safe).
#     e.g. https://<project>.supabase.co/storage/v1/object/public/curriculum
CONTENT_STORE=public
CONTENT_BASE_URL=

# Importer only (scripts/import-curriculum.mjs) — see scripts/README.md.
# Comma-separated AUTHORIZED source hostnames you may download PDFs from. The
# importer refuses any host not listed here (it is not a general proxy).
SOURCE_ALLOWLIST=
# Supabase store bucket for imported PDFs (default: curriculum)
CONTENT_BUCKET=curriculum

# SEO — production domain (no trailing slash). Powers canonical URLs, sitemap.xml,
# robots.txt, Open Graph & Twitter cards. Falls back to VERCEL_URL, then localhost.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase — Database & Auth
# Get from Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_anon_key_here
# REQUIRED for account deletion (/api/account/delete) and the payment webhook.
# Server-side ONLY — never expose to the browser. Without a REAL value (not this
# placeholder) those features return a friendly "not configured" error.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Lemon Squeezy — optional. Elite checkout + webhook. If unset, the app shows a
# truthful "سيتم تفعيل الدفع قريبًا" and never fakes a subscription.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

