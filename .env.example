# Copy this file to .env.local and fill in real values.

# Google Gemini — required for the AI Assistant (server-side only, never NEXT_PUBLIC)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional model override (defaults to a sensible Gemini flash model)
GEMINI_MODEL=

# Clerk — optional. Leave blank to run in guest/demo mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Payments — UI only in this prototype
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Support
NEXT_PUBLIC_SUPPORT_WHATSAPP=966573902089

# SEO — production domain (no trailing slash). Powers canonical URLs, sitemap.xml,
# robots.txt, Open Graph & Twitter cards. Falls back to VERCEL_URL, then localhost.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase — Database & Auth
# Get from Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_anon_key_here
# REQUIRED for account deletion (/api/account/delete) and the payment webhook.
# Server-side ONLY — never expose to the browser. Without a REAL value (not this
# placeholder) those features return a friendly "not configured" error.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Lemon Squeezy — optional. Elite checkout + webhook. If unset, the app shows a
# truthful "سيتم تفعيل الدفع قريبًا" and never fakes a subscription.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

