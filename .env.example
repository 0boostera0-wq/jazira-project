# Copy this file to .env.local and fill in real values.

# Google Gemini — required for the AI Assistant
GEMINI_API_KEY=your_gemini_api_key_here

# Clerk — optional. Leave blank to run in guest/demo mode.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Payments — UI only in this prototype
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Support
NEXT_PUBLIC_SUPPORT_WHATSAPP=966573902089

# Supabase — Database & Auth
# Get from Supabase Dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

